{
    "manifest_version": 3,
    "name": "Backstone Capend DNS monitor",
    "version": "1.0",
    "description": "Monitors connections for safety purposes.",
    "permissions": [
      "webRequest",
      "webRequestBlocking",
      "webNavigation",
      "tabs",
      "storage"
    ],
    "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
    },
    "action": {
        "default_popup": "html/popup.html",
        "default_icon": {
            "16": "images/icon-16.png",
            "32": "images/icon-32.png",
            "48": "images/icon-48.png",
            "128": "images/icon-128.png"
    }
    },
    "host_permissions": [
    "<all_urls>"
    ],
    "background": {
    "service_worker": "scripts_/background.js"
    },

    "web_accessible_resources": [
    {
      "resources": [
        "html/blacklist_interstitial.html",
        "scripts_/blacklist_interstitial.js",
        "html/safe_interstitial.html",
        "scripts_/safe_interstitial.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}